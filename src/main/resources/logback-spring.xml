<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Register Spring Boot's color and exception converters explicitly.
         Required in Spring Boot 4.x when providing a custom logback-spring.xml. -->
    <conversionRule conversionWord="clr"
                    converterClass="org.springframework.boot.logging.logback.ColorConverter" />
    <conversionRule conversionWord="wEx"
                    converterClass="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter" />

    <!-- ================================================================
         PROPERTIES
    ================================================================ -->
    <springProperty name="APP_NAME" source="spring.application.name" defaultValue="marketing-automation"/>
    <property name="LOG_DIR"     value="logs"/>
    <property name="LOG_FILE"    value="${LOG_DIR}/${APP_NAME}"/>
    <property name="MAX_HISTORY" value="30"/>
    <property name="MAX_SIZE"    value="50MB"/>

    <!-- ================================================================
         CONSOLE APPENDER  (colored, human-readable)
    ================================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="ch.qos.logback.classic.encoder.PatternLayoutEncoder">
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p){highlight} %clr([%15.15t]){faint} %clr(%-50.50logger{49}){cyan} %clr(:){faint} %m%n%wEx</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ================================================================
         FILE APPENDER  (rolling daily, plain text for grep/tail)
    ================================================================ -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_FILE}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5p [%t] %-50.50logger{49} : %m%n%ex</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ================================================================
         LOGGER LEVELS
    ================================================================ -->

    <!-- Our application code — DEBUG so every service log prints -->
    <logger name="com.medplus" level="DEBUG" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Spring Security — INFO keeps auth decisions visible without spam -->
    <logger name="org.springframework.security" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Spring Web (request mapping, handler dispatch) -->
    <logger name="org.springframework.web" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Flyway migrations -->
    <logger name="org.flywaydb" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- JDBC / connection pool — WARN to suppress per-query noise -->
    <logger name="org.springframework.jdbc" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>
    <logger name="com.zaxxer.hikari" level="WARN" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- ================================================================
         ROOT  (everything else — INFO)
    ================================================================ -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
